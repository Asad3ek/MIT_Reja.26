<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AADI | Official Website</title>
    <link rel="stylesheet" href="aadi_main.css">
    <link rel="stylesheet" 
     href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
     integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" 
     crossorigin="anonymous">
</head>
<body style="background-color:silver;">
    <div style="background-color:#fff; width: 50%; border: 2px solid #fff; border-radius: 15px;margin-top: 100px;" class="container text-center">
        <div style="width: 60%;" class="container text-center;mb-4 mt-4">
            <h2 style="background-color: midnightblue; color: #fff; border-radius: 8px; padding: 10px 10px;" class="mb-4 mt-4">
                aadi<i>club</i>
            </h2>
        </div>
        <h1>Welcome!</h1>
        <p class="mb-5">Sign in or create your account:</p>

        <form action="/create_item" method="POST">
            <div style="width: 60%;" class="container mb-3 text-start">
                <label for="exampleInputEmail1" class="form-label">Email address</label>
                <input type="email" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">
                <div id="emailHelp" class="form-text">We'll never share your email with anyone else.</div>
            </div>

            <div style="width: 60%;" class="container mb-3 text-start">
                <label for="exampleInputPassword1" class="form-label">Password</label>
                <input type="password" class="form-control" id="exampleInputPassword1">
            </div>

            <div style="width: 60%;" class="container mb-4 text-start">
                <input type="checkbox" class="form-check-input" id="exampleCheck1">
                <label class="form-check-label" for="exampleCheck1">Check me out</label>
            </div>
            <button type="submit" class="btn btn-primary mb-5">Submit</button>
        </form>
        

    </div>
    
</body>
</html>